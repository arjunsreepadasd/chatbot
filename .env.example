# ─────────────────────────────────────────────
# 🤖 AI Chatbot — Environment Variables
# Copy this file to .env and fill in the values
# ─────────────────────────────────────────────

# ── Required ──────────────────────────────────
# Google Gemini API key (get one at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Flask session secret — change to any long random string in production
SECRET_KEY=change-this-in-production-abc123

# ── Redis (optional — app works without it) ───
# Hostname of your Redis server (use "redis" inside Docker Compose)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Leave blank if your Redis has no password
REDIS_PASSWORD=

# ── Cache TTL settings ────────────────────────
# How long to cache identical API responses (seconds). Default: 86400 (24 h)
CACHE_TTL=86400
# How long to keep conversation history in Redis (seconds). Default: 604800 (7 days)
HISTORY_TTL=604800
