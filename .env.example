# ── Required ───────────────────────────────────────────────────────────────────
# Google Gemini API key – get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Flask secret key – change this to a long random string in production
SECRET_KEY=change-this-in-production-abc123

# ── Redis (optional – defaults shown) ─────────────────────────────────────────
# If Redis is not available the app falls back to in-process memory storage.
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=           # Uncomment if your Redis requires authentication
